# Phase 5 — Supabase Edge secrets (Stripe only)
#
# 1. Copy this file to: supabase/.env.stripe
# 2. Fill in real values (that file is gitignored).
# 3. From the LetsGo app folder run: npm run secrets:stripe
#
# Do not prefix these with SUPABASE_; the Edge runtime provides SUPABASE_* automatically.

STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# Optional. Omit both to use the default HTTPS return URL (Stripe rejects exp:// and custom schemes).
# Must match the URL shown on the driver Stripe screen and openAuthSessionAsync in the app.
# STRIPE_CONNECT_RETURN_URL=https://YOUR_PROJECT.supabase.co/functions/v1/create-connect-account-return
# STRIPE_CONNECT_REFRESH_URL=https://YOUR_PROJECT.supabase.co/functions/v1/create-connect-account-return

# Optional dev-only: relaxes PaymentIntent checks in create-trip. Omit or false in production.
# STRIPE_SKIP_VALIDATE=true
