# Copy to .env (do not commit .env). Values from Supabase → Project Settings → API.
#
# Sign-up confirmation emails: Supabase → Authentication → URL Configuration → Redirect URLs must include:
#   letsgo://**   (production / dev build scheme from app.config.js)
#   exp://**      (Expo Go)
# Optional: force exact redirect if the default does not match allowlist (paste same URL in Supabase):
EXPO_PUBLIC_AUTH_EMAIL_REDIRECT=letsgo://verify-otp
# Debug signup mail 500: omit emailRedirectTo (uses Supabase Site URL only). Remove after testing.
EXPO_PUBLIC_AUTH_SIGNUP_OMIT_EMAIL_REDIRECT=true
EXPO_PUBLIC_SUPABASE_URL=https://vbvlytmfnozsjldzgdcr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZidmx5dG1mbm96c2psZHpnZGNyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MTM4NDksImV4cCI6MjA5MDQ4OTg0OX0.R_vQ78QQpzYyMgMcRxzqfaHmT9EHqr2RakG4qNG4cNU

